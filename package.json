{
  "name": "vertex",
  "version": "1.0.0",
  "description": "Vertex — 3D version control for Blender scenes",
  "main": "server/index.js",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "start": "node server/index.js",
    "install:frontend": "cd frontend && npm install"
  },
  "keywords": ["blender", "3d", "version-control"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
